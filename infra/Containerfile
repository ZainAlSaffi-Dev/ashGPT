# FastAPI backend container — used by docker-compose locally and Cloudflare Containers in prod.
# Build context: ./backend (so requirements.txt and src/ resolve relative to /app).

FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# System deps for PyMuPDF + Pillow + sentence-transformers.
# torch/sentence-transformers get removed in Phase 5 (Cohere Rerank API replacement) —
# this layer shrinks substantially then.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libgl1 \
        libglib2.0-0 \
        libjpeg62-turbo \
        libpng16-16 \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./
RUN pip install -r requirements.txt

COPY . .

EXPOSE 8000

# api/main.py is added in Phase 1. Until then this CMD will fail — that is expected.
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
