{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://lawgpt-15s.pages.dev",
          "http://localhost:3000"
        ],
        "methods": ["PUT", "GET", "HEAD"],
        "headers": [
          "content-type",
          "content-length",
          "authorization",
          "x-amz-content-sha256",
          "x-amz-date",
          "x-amz-user-agent",
          "x-amz-acl"
        ]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
