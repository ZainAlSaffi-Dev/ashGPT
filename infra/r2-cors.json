{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://ashgpt.xyz",
          "https://www.ashgpt.xyz",
          "http://localhost:3000",
          "http://127.0.0.1:3000"
        ],
        "methods": ["PUT", "GET", "HEAD"],
        "headers": [
          "content-type",
          "content-length",
          "authorization",
          "x-amz-content-sha256",
          "x-amz-date",
          "x-amz-user-agent",
          "x-amz-acl"
        ]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
